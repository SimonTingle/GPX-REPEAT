# GPX Repeat Environment Variables
# Copy this to .env and adjust values as needed
# Do NOT commit .env to Git — use .env.local or set variables in CapRover Dashboard

# Flask Environment
FLASK_ENV=production

# Python unbuffered output (for real-time logs)
PYTHONUNBUFFERED=1

# Server Port (CapRover sets this automatically)
PORT=5000

# Optional: Max file upload size (in bytes)
# Default: 50 MB (50 * 1024 * 1024)
# MAX_FILE_SIZE=52428800

# Optional: Allowed origins for CORS (comma-separated)
# Default: * (all origins allowed)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Optional: Data persistence directory
# Default: /app/data (in Docker)
# DATA_DIR=/app/data

# Optional: Enable debug mode (development only, never production)
# DEBUG=0
